{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Flask Dashboard",
            "type": "debugpy",
            "request": "launch",
            "module": "flask",
            "env": {
                "FLASK_APP": "investigation_dashboard.py",
                "FLASK_DEBUG": "1"
            },
            "args": [
                "run",
                "--no-debugger",
                "--no-reload",
                "--port", "5002"
            ],
            "jinja": true,
            "autoStartBrowser": true
        }
    ]
}
